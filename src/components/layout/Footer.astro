---
export interface Props {
  base: string;
}
const { base } = Astro.props;
---

<footer class="border-t border-border mt-auto py-8 px-4">
  <div class="max-w-5xl mx-auto flex flex-col sm:flex-row items-center justify-between gap-4 text-sm text-muted">
    <p class="font-mono">
      <span class="text-text">disc</span><span class="text-cyan">AR</span><span class="text-text">d</span>
      <span class="ml-2">— Discord AR 電子名刺</span>
    </p>
    <nav class="flex gap-6">
      <a href={`${base}/`} class="hover:text-text transition-colors">ホーム</a>
      <a href={`${base}/card`} class="hover:text-text transition-colors">マイ名刺</a>
      <a href={`${base}/ar`} class="hover:text-text transition-colors">AR カメラ</a>
    </nav>
  </div>
</footer>
