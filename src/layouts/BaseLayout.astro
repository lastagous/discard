---
import '../styles/global.css';
import Header from '../components/layout/Header.svelte';
import Footer from '../components/layout/Footer.astro';

export interface Props {
  title: string;
  description: string;
  ogImage?: string;
  hideHeader?: boolean;
}

const { title, description, ogImage, hideHeader = false } = Astro.props;
const canonical = new URL(Astro.url.pathname, Astro.site);
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<!DOCTYPE html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="index, follow" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <!-- OGP -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    {ogImage && <meta property="og:image" content={ogImage} />}
    <meta property="og:locale" content="ja_JP" />
    <meta property="og:site_name" content="discARd" />
    <meta name="twitter:card" content="summary_large_image" />

    <!-- Favicon -->
    <link rel="icon" type="image/png" href={`${base}/favicon-hat.png`} />

    <script type="application/ld+json" set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'WebSite',
      name: 'discARd',
      url: 'https://lastagous.com/discARd',
    })} />
  </head>
  <body>
    {!hideHeader && <Header client:load base={base} />}
    <main class={hideHeader ? '' : 'pt-16'}>
      <slot />
    </main>
    <Footer base={base} />
  </body>
</html>
