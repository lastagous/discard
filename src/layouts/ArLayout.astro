---
import '../styles/global.css';

export interface Props {
  title: string;
}

const { title } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<!DOCTYPE html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no" />
    <title>{title}</title>
    <link rel="icon" type="image/png" href={`${base}/favicon-hat.png`} />
    <style>
      * { margin: 0; padding: 0; box-sizing: border-box; }
      html, body { width: 100%; height: 100%; overflow: hidden; background: #000; }

      #ar-overlay {
        position: fixed;
        top: 0; left: 0; right: 0;
        z-index: 999;
        padding: 12px 16px;
        display: flex;
        align-items: center;
        gap: 10px;
        background: linear-gradient(to bottom, rgba(10,10,20,0.85) 60%, transparent);
        pointer-events: none;
      }

      #ar-overlay > * { pointer-events: auto; }

      .ar-back-btn {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 6px 14px;
        border-radius: 8px;
        border: 1px solid rgba(0, 212, 255, 0.4);
        background: rgba(10, 10, 20, 0.8);
        color: #00d4ff;
        font-family: 'Space Grotesk', sans-serif;
        font-size: 13px;
        font-weight: 500;
        text-decoration: none;
        transition: border-color 0.2s, background 0.2s;
      }

      .ar-back-btn:hover {
        border-color: #00d4ff;
        background: rgba(0, 212, 255, 0.1);
      }

      #ar-status {
        flex: 1;
        padding: 6px 12px;
        border-radius: 8px;
        background: rgba(10, 10, 20, 0.8);
        border: 1px solid rgba(255, 255, 255, 0.1);
        color: #dcddde;
        font-family: 'Space Grotesk', sans-serif;
        font-size: 12px;
      }

      #ar-logo {
        padding: 6px 12px;
        border-radius: 8px;
        background: rgba(10, 10, 20, 0.8);
        border: 1px solid rgba(88, 101, 242, 0.4);
        color: #5865F2;
        font-family: 'JetBrains Mono', monospace;
        font-size: 12px;
        font-weight: 600;
        letter-spacing: 0.05em;
      }

      #ar-hint {
        position: fixed;
        bottom: 24px;
        left: 50%;
        transform: translateX(-50%);
        z-index: 999;
        padding: 10px 16px;
        border-radius: 24px;
        background: rgba(10, 10, 20, 0.85);
        border: 1px solid rgba(0, 212, 255, 0.3);
        color: #72767d;
        font-family: 'Space Grotesk', sans-serif;
        font-size: 12px;
        text-align: center;
        white-space: nowrap;
        max-width: calc(100vw - 32px);
        overflow: hidden;
        text-overflow: ellipsis;
        pointer-events: none;
      }
    </style>
  </head>
  <body>
    <slot />
  </body>
</html>
