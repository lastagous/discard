---
import ArLayout from '../layouts/ArLayout.astro';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const workerUrl = import.meta.env.PUBLIC_WORKER_URL;
---

<ArLayout title="AR カメラ | discARd">

  <!-- タップ起動画面（iOS Safari 対応） -->
  <div id="tap-screen" style="
    position: fixed; inset: 0; z-index: 9999;
    background: #0a0a14;
    display: flex; flex-direction: column;
    align-items: center; justify-content: center; gap: 24px;
  ">
    <div style="font-family: monospace; font-size: 22px; color: #00d4ff; font-weight: bold;">
      disc<span style="color:#5865F2">AR</span>d
    </div>
    <p style="color: #72767d; font-size: 14px;">AR カメラを起動します</p>
    <button id="start-btn" style="
      padding: 16px 40px; border-radius: 12px;
      background: #5865F2; color: white;
      border: none; font-size: 16px; font-weight: 600;
      cursor: pointer;
    ">
      タップしてカメラを起動
    </button>
    <p id="tap-error" style="color: #ed4245; font-size: 13px; display: none;"></p>
  </div>

  <!-- AR シーン（タップ後に挿入） -->
  <div id="ar-container" style="display:none; position:fixed; inset:0; z-index:1;"></div>

  <!-- UI オーバーレイ -->
  <div id="ar-overlay" style="display:none;">
    <a href={`${base}/`} class="ar-back-btn">← 戻る</a>
    <div id="ar-status">カメラを起動中...</div>
    <div id="ar-logo">discARd</div>
  </div>

  <!-- 使い方ヒント -->
  <div id="ar-hint" style="display:none;">
    Hiro マーカーにカメラを向けてください &nbsp;·&nbsp;
    <a href={`${base}/marker`} target="_blank" style="color:#00d4ff;">マーカーを表示</a>
  </div>

  <!-- A-Frame と AR.js を CDN から読み込む -->
  <script is:inline src="https://aframe.io/releases/1.4.0/aframe.min.js"></script>
  <script is:inline src="https://cdn.jsdelivr.net/gh/AR-js-org/AR.js@3.4.5/aframe/build/aframe-ar.js"></script>

  <script is:inline define:vars={{ base, workerUrl }}>
    const params = new URLSearchParams(location.search);
    const userId = params.get('user');

    document.getElementById('start-btn').addEventListener('click', async function () {
      const errEl = document.getElementById('tap-error');
      this.textContent = '起動中...';
      this.disabled = true;

      // カメラストリームを取得（このストリームを背景 video と AR.js 両方で使う）
      let cameraStream;
      try {
        cameraStream = await navigator.mediaDevices.getUserMedia({
          video: { facingMode: 'environment' }
        });
      } catch (e) {
        errEl.textContent = 'カメラへのアクセスが拒否されました。設定からカメラを許可してください。';
        errEl.style.display = 'block';
        this.textContent = 'タップしてカメラを起動';
        this.disabled = false;
        return;
      }

      // ネイティブ <video> を背景として表示（iOS WebGL 問題を回避）
      const bgVideo = document.createElement('video');
      bgVideo.setAttribute('playsinline', '');
      bgVideo.setAttribute('webkit-playsinline', '');
      bgVideo.setAttribute('autoplay', '');
      bgVideo.muted = true;
      bgVideo.srcObject = cameraStream;
      Object.assign(bgVideo.style, {
        position: 'fixed',
        top: '0', left: '0',
        width: '100vw', height: '100vh',
        objectFit: 'cover',
        zIndex: '0',
        pointerEvents: 'none',
      });
      document.body.appendChild(bgVideo);
      bgVideo.play().catch(() => {});

      // AR.js の getUserMedia を横取りしてクローンストリームを渡す
      // clone() により AR.js が独立してストリームを管理でき、loadedmetadata が正常に発火する
      const _origGUM = navigator.mediaDevices.getUserMedia.bind(navigator.mediaDevices);
      navigator.mediaDevices.getUserMedia = (c) => {
        if (c && c.video) return Promise.resolve(cameraStream.clone());
        return _origGUM(c);
      };

      // タップ画面を非表示にして AR を表示
      document.getElementById('tap-screen').style.display = 'none';
      document.getElementById('ar-overlay').style.display = 'flex';
      document.getElementById('ar-hint').style.display = 'block';

      // a-scene を動的に挿入（WebGL は alpha:true で透明にして 3D のみ描画）
      const container = document.getElementById('ar-container');
      container.style.display = 'block';
      container.innerHTML = `
        <a-scene
          id="ar-scene"
          embedded
          style="width:100%;height:100%;"
          arjs="sourceType: webcam; debugUIEnabled: false; detectionMode: mono; changeMatrixMode: modelViewMatrix;"
          renderer="alpha: true; antialias: false;"
          vr-mode-ui="enabled: false"
          loading-screen="enabled: false"
        >
          <a-assets id="ar-assets">
            <img id="avatar-asset" src="" crossorigin="anonymous" />
          </a-assets>
          <a-marker preset="hiro" id="ar-marker" smooth="true" smoothCount="10" smoothTolerance="0.01">
            <a-entity id="card-root" position="0 0 0">
              <a-plane id="card-bg" width="3.6" height="2.2" position="0 0.55 0" rotation="-90 0 0" material="color: #1a1a2e; opacity: 0.96; shader: flat"></a-plane>
              <a-plane width="3.6" height="0.02" position="0 1.66 0" rotation="-90 0 0" material="color: #00d4ff; opacity: 0.8; shader: flat"></a-plane>
              <a-plane width="0.02" height="2.2" position="-1.8 0.55 0" rotation="-90 0 0" material="color: #5865F2; opacity: 0.6; shader: flat"></a-plane>
              <a-circle id="avatar-circle" radius="0.38" position="-1.3 0.55 0.02" rotation="-90 0 0" material="shader: flat"></a-circle>
              <a-torus radius="0.4" radius-tubular="0.02" position="-1.3 0.55 0.01" rotation="-90 0 0" material="color: #00d4ff; opacity: 0.7; shader: flat"></a-torus>
              <a-text id="ar-display-name" value="Loading..." position="-0.7 1.1 0.02" rotation="-90 0 0" color="#ffffff" width="6" anchor="left" baseline="center" font="roboto"></a-text>
              <a-text id="ar-handle" value="" position="-0.7 0.82 0.02" rotation="-90 0 0" color="#5865F2" width="5" anchor="left" baseline="center" font="roboto"></a-text>
              <a-plane width="2.6" height="0.01" position="0.2 0.65 0.02" rotation="-90 0 0" material="color: #2a2a4e; opacity: 0.8; shader: flat"></a-plane>
              <a-text id="ar-bio" value="" position="-0.7 0.42 0.02" rotation="-90 0 0" color="#9999bb" width="5.5" anchor="left" baseline="top" wrap-count="44" font="roboto"></a-text>
              <a-text value="discARd" position="1.6 0.12 0.02" rotation="-90 0 0" color="#00d4ff" width="2.5" anchor="right" baseline="center" font="roboto"></a-text>
              <a-text id="ar-marker-id" value="" position="-1.7 0.12 0.02" rotation="-90 0 0" color="#4a4a6a" width="2" anchor="left" baseline="center" font="roboto"></a-text>
            </a-entity>
          </a-marker>
          <a-entity camera></a-entity>
        </a-scene>
      `;

      // AR.js が内部 video を作ったら非表示にする（bgVideo で表示するため）
      const hideArJsVideo = () => {
        document.querySelectorAll('video').forEach(v => {
          if (v !== bgVideo) {
            v.style.visibility = 'hidden';
            v.style.position = 'fixed';
          }
        });
      };
      [500, 1000, 2000].forEach(t => setTimeout(hideArJsVideo, t));

      await initAR();
    });

    async function initAR() {
      const statusEl = document.getElementById('ar-status');

      if (!userId) {
        statusEl.textContent = '⚠️ ユーザーIDが指定されていません';
        return;
      }

      let user;
      try {
        const res = await fetch(`${workerUrl}/api/user/${userId}`);
        if (!res.ok) throw new Error('not found');
        user = await res.json();
      } catch (e) {
        statusEl.textContent = '⚠️ ユーザーデータの取得に失敗しました';
        return;
      }

      const displayName = user.global_name || user.username;
      statusEl.textContent = `${displayName} の名刺を探しています...`;

      const scene = document.getElementById('ar-scene');

      function applyUserData() {
        document.getElementById('ar-display-name').setAttribute('value', displayName);
        document.getElementById('ar-handle').setAttribute('value', `@${user.username}`);
        document.getElementById('ar-bio').setAttribute('value', user.bio || '');
        document.getElementById('ar-marker-id').setAttribute('value', `No.${user.marker_id}`);

        if (user.avatar) {
          const url = `https://cdn.discordapp.com/avatars/${user.id}/${user.avatar}.png?size=128`;
          document.getElementById('avatar-asset').setAttribute('src', url);
          document.getElementById('avatar-circle').setAttribute('material', 'src: #avatar-asset; shader: flat');
        }
      }

      if (scene.hasLoaded) {
        applyUserData();
      } else {
        scene.addEventListener('loaded', applyUserData);
      }

      const marker = document.getElementById('ar-marker');
      const hint = document.getElementById('ar-hint');

      marker.addEventListener('markerFound', () => {
        statusEl.textContent = `✓ ${displayName} の名刺を検出`;
        hint.style.display = 'none';
      });

      marker.addEventListener('markerLost', () => {
        statusEl.textContent = `${displayName} の名刺を探しています...`;
        hint.style.display = 'block';
      });
    }
  </script>
</ArLayout>
