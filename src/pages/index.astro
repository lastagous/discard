---
import BaseLayout from '../layouts/BaseLayout.astro';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const workerUrl = import.meta.env.PUBLIC_WORKER_URL;
---

<BaseLayout
  title="discARd — Discord AR 電子名刺"
  description="Discord アカウントでログインして、AR で共有できる電子名刺を作成・交換するサービスです。"
>
  <!-- ヒーローセクション -->
  <section class="relative min-h-[calc(100vh-4rem)] flex items-center justify-center px-4 py-20">
    <!-- 背景グロウ -->
    <div class="absolute inset-0 overflow-hidden pointer-events-none">
      <div class="absolute top-1/4 left-1/2 -translate-x-1/2 w-[600px] h-[600px] rounded-full opacity-10"
        style="background: radial-gradient(circle, #5865F2 0%, transparent 70%);"></div>
      <div class="absolute bottom-1/4 left-1/3 w-[400px] h-[400px] rounded-full opacity-8"
        style="background: radial-gradient(circle, #00d4ff 0%, transparent 70%);"></div>
    </div>

    <div class="relative z-10 text-center max-w-2xl mx-auto">
      <!-- ロゴ -->
      <div class="mb-8 animate-float">
        <p class="section-label mb-3">AUGMENTED REALITY BUSINESS CARD</p>
        <h1 class="text-6xl md:text-7xl font-bold tracking-tight mb-2">
          <span class="text-text">disc</span><span class="text-glow-cyan">AR</span><span class="text-text">d</span>
        </h1>
        <p class="text-muted text-lg font-light mt-3">
          Discord の情報を AR 電子名刺に変換して共有
        </p>
      </div>

      <!-- カード プレビュー (静的デモ) -->
      <div class="card-glass card-glow max-w-sm mx-auto p-5 mb-10 text-left relative overflow-hidden">
        <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-cyan to-transparent opacity-60"></div>
        <div class="flex items-center gap-4">
          <div class="w-14 h-14 rounded-full border-2 border-primary flex-shrink-0 flex items-center justify-center bg-surface text-2xl">
            👾
          </div>
          <div>
            <p class="font-bold text-text">あなたの名前</p>
            <p class="text-xs text-primary font-mono">@username</p>
            <p class="text-xs text-muted mt-1">自己紹介がここに表示されます</p>
          </div>
        </div>
        <div class="mt-4 pt-4 border-t border-border flex gap-3 items-center">
          <div class="w-12 h-12 bg-white rounded flex-shrink-0 opacity-80 text-center text-xs text-black flex items-center justify-center font-bold leading-tight">
            AR<br>MRK
          </div>
          <div class="flex-1 text-xs text-muted">
            <p>→ AR マーカーをカメラで読み取ると</p>
            <p class="text-cyan">名刺が現実空間に浮かびあがります</p>
          </div>
        </div>
      </div>

      <!-- ログインボタン -->
      <div id="login-section">
        <a
          href={`${workerUrl}/auth/login`}
          class="btn-primary text-base px-10 py-4 shadow-lg"
          style="box-shadow: 0 0 24px rgba(88,101,242,0.4);"
        >
          <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor" class="flex-shrink-0">
            <path d="M20.317 4.37a19.791 19.791 0 0 0-4.885-1.515.074.074 0 0 0-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0 12.64 12.64 0 0 0-.617-1.25.077.077 0 0 0-.079-.037A19.736 19.736 0 0 0 3.677 4.37a.07.07 0 0 0-.032.027C.533 9.046-.32 13.58.099 18.057.1 18.08.11 18.1.128 18.11a19.9 19.9 0 0 0 5.993 3.03.077.077 0 0 0 .084-.028c.462-.63.874-1.295 1.226-1.994a.076.076 0 0 0-.041-.106 13.107 13.107 0 0 1-1.872-.892.077.077 0 0 1-.008-.128 10.2 10.2 0 0 0 .372-.292.074.074 0 0 1 .077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 0 1 .078.01c.12.098.246.198.373.292a.077.077 0 0 1-.006.127 12.299 12.299 0 0 1-1.873.892.077.077 0 0 0-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 0 0 .084.028 19.839 19.839 0 0 0 6.002-3.03.077.077 0 0 0 .032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 0 0-.031-.03z"/>
          </svg>
          Discord でログイン
        </a>
        <p class="text-muted text-xs mt-3">アカウント情報の読み取りのみ。投稿権限は不要。</p>
      </div>

      <!-- ログイン済みの場合の表示 -->
      <div id="logged-in-section" class="hidden">
        <a href={`${base}/card`} class="btn-primary text-base px-10 py-4">
          マイ名刺を見る →
        </a>
      </div>
    </div>
  </section>

  <!-- 使い方セクション -->
  <section class="max-w-4xl mx-auto px-4 pb-20">
    <p class="section-label text-center mb-10">HOW IT WORKS</p>
    <div class="grid md:grid-cols-3 gap-6">
      {[
        {
          step: '01',
          title: 'Discord でログイン',
          desc: 'Discord アカウントで認証するだけ。ユーザー名・アバターが自動取得されます。',
          icon: '🔐',
        },
        {
          step: '02',
          title: 'AR 名刺を受け取る',
          desc: 'あなた専用の AR マーカーと名刺が生成されます。自己紹介文も編集できます。',
          icon: '🪪',
        },
        {
          step: '03',
          title: 'AR カメラで共有',
          desc: 'QR コードをシェアすると、相手が AR カメラで名刺を現実空間に表示できます。',
          icon: '📡',
        },
      ].map(item => (
        <div class="card-glass p-6 relative overflow-hidden group hover:border-primary transition-colors">
          <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-primary to-transparent opacity-0 group-hover:opacity-50 transition-opacity"></div>
          <p class="font-mono text-primary text-xs mb-3">{item.step}</p>
          <p class="text-3xl mb-3">{item.icon}</p>
          <h3 class="font-semibold text-text mb-2">{item.title}</h3>
          <p class="text-sm text-muted">{item.desc}</p>
        </div>
      ))}
    </div>
  </section>
</BaseLayout>

<script is:inline define:vars={{ base }}>
  // ログイン済みチェック
  const token = localStorage.getItem('discard_token');
  if (token) {
    document.getElementById('login-section')?.classList.add('hidden');
    document.getElementById('logged-in-section')?.classList.remove('hidden');
  }

  // エラーパラメータ表示
  const params = new URLSearchParams(location.search);
  const error = params.get('error');
  if (error) {
    const msgs = {
      missing_code: '認証コードが取得できませんでした。再試行してください。',
      token_exchange: 'Discord との認証に失敗しました。再試行してください。',
      user_fetch: 'ユーザー情報の取得に失敗しました。再試行してください。',
    };
    const el = document.createElement('div');
    el.className = 'mt-4 text-sm text-red bg-red/10 border border-red/30 rounded-lg px-4 py-3';
    el.textContent = msgs[error] ?? 'エラーが発生しました。再試行してください。';
    document.getElementById('login-section')?.appendChild(el);
  }
</script>
